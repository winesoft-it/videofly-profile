{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "video-profile/v1/schemas/rendition.schema.json",
  "title": "Video Profile Rendition",
  "description": "VideoFly video profile 안의 단일 출력 rendition 정의. 예: 1080p, 720p, 360p, 144p.",
  "type": "object",
  "required": ["name", "container", "audio", "video"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^(fmp4|m2ts)_[a-z0-9][a-z0-9_.-]*$",
      "description": "profile 안에서 rendition을 식별하는 고유 이름. {container}_{name} 규칙을 사용한다. 예: fmp4_1080p, m2ts_1080p, fmp4_720p."
    },
    "container": {
      "type": "string",
      "enum": ["fmp4", "m2ts"],
      "description": "rendition이 제공되는 HLS 패키징 컨테이너."
    },
    "bandwidth": {
      "type": "integer",
      "minimum": 1,
      "description": "HLS master playlist의 BANDWIDTH fallback 값(bps). 실제 산출 bandwidth를 동적으로 얻을 수 없을 때만 사용한다."
    },
    "audio": {
      "type": "object",
      "properties": {
        "enable": {
          "type": "boolean",
          "description": "이 rendition에 오디오를 포함할지 여부."
        },
        "codec": {
          "type": "string",
          "enum": ["aac", "ac3", "eac3", "opus"],
          "description": "오디오 코덱. 값이 없으면 원본 유지 또는 구현 기본 정책을 따른다."
        },
        "codec_options": {
          "type": "object",
          "properties": {
            "profile": {
              "type": "string",
              "enum": ["aac_low", "aac_he", "aac_he_v2", "auto"],
              "description": "오디오 코덱 프로파일. AAC 기준 aac_low는 AAC-LC에 대응한다."
            }
          },
          "additionalProperties": false
        },
        "sample_rate": {
          "type": "integer",
          "minimum": 1,
          "description": "오디오 샘플레이트(Hz)."
        },
        "bit_rate": {
          "type": "integer",
          "minimum": 1,
          "description": "목표 오디오 비트레이트(bps)."
        },
        "channels": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8,
          "description": "오디오 채널 수."
        }
      },
      "additionalProperties": false
    },
    "video": {
      "type": "object",
      "properties": {
        "enable": {
          "type": "boolean",
          "description": "이 rendition에 비디오를 포함할지 여부."
        },
        "codec": {
          "type": "string",
          "enum": ["h264", "av1"],
          "description": "논리적 비디오 코덱. 값이 없으면 원본 유지 또는 구현 기본 정책을 따른다. 실제 인코더 이름은 구현 정책에서 결정한다."
        },
        "gpu": {
          "type": "object",
          "required": ["quality"],
          "description": "GPU 인코더 preset과 quality 설정.",
          "properties": {
            "preset": {
              "type": "string",
              "pattern": "^p[1-7]$",
              "description": "GPU 인코더 속도/품질 preset. v1에서는 p1-p7 값을 사용한다."
            },
            "quality": {
              "type": "integer",
              "minimum": 1,
              "maximum": 63,
              "description": "GPU 인코더 품질 튜닝 값. 변환 구현에서는 cq 값 조정에 사용한다. 낮을수록 고품질이다."
            }
          },
          "additionalProperties": false
        },
        "cpu": {
          "type": "object",
          "required": ["quality"],
          "description": "CPU 인코더 preset과 quality 설정. GPU 사용이 불가능한 경우 사용할 수 있다.",
          "properties": {
            "preset": {
              "type": "string",
              "description": "CPU 인코더 속도/품질 preset. 실제 허용 범위는 구현 인코더 정책에서 결정한다."
            },
            "quality": {
              "type": "integer",
              "minimum": 1,
              "maximum": 63,
              "description": "CPU 인코더 품질 튜닝 값. 변환 구현에서는 crf 값 조정에 사용한다. 낮을수록 고품질이다."
            }
          },
          "additionalProperties": false
        },
        "codec_options": {
          "type": "object",
          "properties": {
            "profile": {
              "type": "string",
              "description": "적용 가능한 경우의 코덱 프로파일. 예: baseline, main, high."
            },
            "level": {
              "type": "string",
              "description": "적용 가능한 경우의 코덱 레벨. 예: 4.0, 4.1."
            },
            "max_bitrate": {
              "type": "integer",
              "minimum": 1,
              "description": "최대 비디오 비트레이트(bps)."
            },
            "min_bitrate": {
              "type": "integer",
              "minimum": 1,
              "description": "최소 비디오 비트레이트(bps)."
            },
            "chroma_subsampling": {
              "type": "string",
              "enum": ["yuv420p", "yuv422p", "yuv444p", "nv12", "auto"],
              "description": "적용 가능한 경우 요청하는 chroma subsampling 또는 pixel format."
            },
            "interlace_mode": {
              "type": "string",
              "enum": ["auto", "progressive", "top_field_first", "bottom_field_first"],
              "description": "출력 interlace 처리 방식. 생략하면 구현 기본 정책을 따른다."
            }
          },
          "additionalProperties": false
        },
        "bit_rate": {
          "type": "integer",
          "minimum": 1,
          "description": "목표 비디오 비트레이트(bps)."
        },
        "frame_rate": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "요청 출력 프레임레이트(fps)."
        },
        "max_frame_rate": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "최대 출력 프레임레이트(fps). 인코더가 이 값을 초과하는 프레임레이트로 출력하지 않도록 한다."
        },
        "resolution": {
          "type": "string",
          "pattern": "^\\d+x\\d+$",
          "description": "{width}x{height} 형식의 목표 해상도. 예: 1280x720."
        },
        "sizing_policy": {
          "type": "string",
          "default": "fit_to_orientation_no_upscale",
          "enum": [
            "fit",
            "fit_to_orientation",
            "fill",
            "stretch",
            "center_crop",
            "fit_no_upscale",
            "fill_no_upscale",
            "fit_to_orientation_no_upscale"
          ],
          "description": "원본을 목표 해상도에 맞추는 방식. 생략하면 fit_to_orientation_no_upscale로 처리한다."
        },
        "padding_policy": {
          "type": "string",
          "enum": ["no_pad", "pad"],
          "description": "sizing_policy 처리 중 남는 영역을 패딩할지 여부. no_pad는 패딩을 추가하지 않는 운영 기본 동작이고, pad는 목표 해상도까지 레터박스 패딩을 추가한다."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
