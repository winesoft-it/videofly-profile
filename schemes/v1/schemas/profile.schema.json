{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "video-profile/v1/schemas/profile.schema.json",
  "title": "Video Profile",
  "description": "VideoFly 출력 profile 정의. 하나의 profile은 공통 생성 정책, HLS 패키징 정책, 하나 이상의 rendition 출력을 포함한다.",
  "type": "object",
  "required": ["schema_version", "name", "renditions"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1",
      "description": "video profile 스키마 버전."
    },
    "name": {
      "type": "string",
      "pattern": "^_?[a-z0-9][a-z0-9_.-]*$",
      "description": "profile을 식별하는 고유 이름. VideoFly 기본 profile은 '_'로 시작할 수 있다. 예: _default, _youtube, _balance."
    },
    "description": {
      "type": "string",
      "description": "profile 설명."
    },
    "rendition_policy": {
      "type": "object",
      "description": "HLS 패키징 전에 rendition 출력을 생성할지, 어떤 조건으로 생성할지 결정하는 정책.",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "always",
            "if_bitrate_exceeds",
            "if_spec_mismatch",
            "if_codec_mismatch"
          ],
          "description": "rendition 트랜스코딩이 필요한지 판단하는 조건."
        },
        "allow_upscale": {
          "type": "boolean",
          "description": "원본보다 큰 해상도의 rendition 생성을 허용할지 여부."
        }
      },
      "additionalProperties": false
    },
    "hls": {
      "type": "object",
      "description": "rendition들이 공유하는 HLS playlist와 segment 패키징 옵션.",
      "properties": {
        "version": {
          "type": "integer",
          "minimum": 1,
          "description": "HLS playlist 버전 또는 정책 버전."
        },
        "path": {
          "type": "string",
          "enum": ["abs", "rel"],
          "description": "생성된 playlist 안에서 segment 경로를 표현하는 방식."
        },
        "split": {
          "type": "string",
          "enum": ["loose", "balance", "strict"],
          "description": "목표 segment 길이를 기준으로 segment를 분할하는 정책."
        },
        "segment_duration": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "목표 HLS segment 길이(초)."
        }
      },
      "additionalProperties": false
    },
    "live": {
      "type": "object",
      "description": "원본 미디어를 live stream처럼 제공하는 profile의 live 재생 정책.",
      "properties": {
        "enable": {
          "type": "boolean",
          "description": "live stream 방식 제공 여부."
        },
        "buffer": {
          "type": "number",
          "minimum": 0,
          "description": "live 재생 버퍼 시간(초)."
        },
        "denial_code": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599,
          "description": "live 요청이 허용된 시간 범위를 벗어났을 때 사용할 HTTP 응답 상태 코드."
        }
      },
      "additionalProperties": false
    },
    "encrypt": {
      "type": "object",
      "description": "HLS EXT-X-KEY 암호화 정책.",
      "properties": {
        "enable": {
          "type": "boolean",
          "description": "HLS 암호화 활성화 여부."
        },
        "key_file_name": {
          "type": "string",
          "minLength": 1,
          "description": "HLS playlist에 기록할 키 파일명."
        },
        "token": {
          "type": "string",
          "description": "암호화 토큰 또는 키 재료. 공유 profile 파일에는 운영용 비밀값을 저장하지 않는 것을 권장한다."
        },
        "token_type": {
          "type": "string",
          "enum": ["raw", "enc"],
          "description": "token 표현 방식. raw는 token을 그대로 사용하고, enc는 암호화된 token을 사용 전에 복호화한다."
        },
        "iv": {
          "type": ["string", "null"],
          "pattern": "^0x[0-9a-fA-F]{32}$",
          "description": "선택적 AES-128 Initial Vector. 0x로 시작하는 16바이트 16진수 문자열을 사용한다."
        }
      },
      "additionalProperties": false
    },
    "event": {
      "type": "object",
      "description": "원본 비디오가 서비스될 때 발생시키는 profile-level 이벤트.",
      "properties": {
        "normalize": {
          "type": "string",
          "enum": ["to_h264_aac"],
          "description": "원본 포맷 표준화를 스케줄링한다."
        }
      },
      "additionalProperties": false
    },
    "renditions": {
      "type": "array",
      "minItems": 1,
      "description": "profile에 포함되는 rendition 출력 목록. 배열 순서는 master playlist variant 출력 순서로 사용할 수 있다.",
      "items": {
        "$ref": "rendition.schema.json"
      }
    }
  },
  "additionalProperties": false
}
